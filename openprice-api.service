[Unit]
Description=OpenPrice API
After=network.target

[Service]
Type=simple
User=debian
WorkingDirectory=/home/debian/OpenPrice-API/openprice-api
ExecStart=/home/debian/OpenPrice-API/openprice-api/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=openprice-api

[Install]
WantedBy=multi-user.target
